{
  "name": "agentic-entity-search",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace server\" \"VITE_API_URL=http://localhost:4000 npm run dev --workspace client\"",
    "dev:server": "npm run dev --workspace server",
    "dev:client": "VITE_API_URL=http://localhost:4000 npm run dev --workspace client",
    "build": "npm run build --workspace client",
    "start": "npm run start --workspace server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
